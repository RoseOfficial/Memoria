# Local development environment variables — copy to .env and fill in.
# The .env file is gitignored; never commit real secrets.

# Neon Postgres connection string. Use the pooled connection URI.
ALPHASCOPE_DB_CONNECTION=postgresql://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Allowed browser origins for CORS (comma separated). Leave empty for no browser clients.
ALPHASCOPE_CORS_ORIGINS=
